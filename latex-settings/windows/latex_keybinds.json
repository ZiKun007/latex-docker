// Place your key bindings in this file to override the defaults auto[]
[
    // ==========================================
    // LaTeX Workshop Commands
    // ==========================================
    {
        "key": "alt+r",
        "command": "latex-workshop.recipes",
        "when": "editorLangId == 'latex'"
    },
    {
        // Changed from bare 'alt' to a specific chord to avoid OS conflicts
        "key": "ctrl+alt+s", 
        "command": "latex-workshop.synctex",
        "when": "editorTextFocus && editorLangId == 'latex'"
    },  

    // ==========================================
    // LaTeX Snippets (Restricted to LaTeX files)
    // ==========================================

    // Display Math
    {
        "key": "alt+m",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && editorLangId == 'latex'",
        "args": {
            "snippet": "$$\n\t${1:$TM_SELECTED_TEXT}\n$$$0" 
        }
    },
    // Inline Math (Removed awkward spacing)
    {
        "key": "alt+shift+m",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && editorLangId == 'latex'",
        "args": {
            "snippet": "$${1:$TM_SELECTED_TEXT}$$0" 
        }
    },
    // Math Bold (\mathbf)
    {
        "key": "alt+shift+b",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && editorLangId == 'latex'",
        "args": {
            "snippet": "\\mathbf{${1:$TM_SELECTED_TEXT}}$0"
        }
    },
    // Bold Math (\bm) - Requires \usepackage{bm}
    {
        "key": "alt+b",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && editorLangId == 'latex'",
        "args": {
            "snippet": "\\bm{${1:$TM_SELECTED_TEXT}}$0" 
        }
    },
    // Subscript
    {
        "key": "alt+d",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && editorLangId == 'latex'",
        "args": {
            "snippet": "_{$1}$0" 
        }
    },
    // Superscript
    {
        "key": "alt+u",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && editorLangId == 'latex'",
        "args": {
            "snippet": "^{$1}$0" 
        }
    },
    // Square Root
    {
        "key": "alt+q",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && editorLangId == 'latex'",
        "args": {
            "snippet": "\\sqrt{${1:$TM_SELECTED_TEXT}}$0" 
        }
    },
    // Fraction
    {
        "key": "alt+f",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && editorLangId == 'latex'",
        "args": {
            // Allows selecting the numerator, then tabbing to denominator
            "snippet": "\\frac{${1:$TM_SELECTED_TEXT}}{$2}$0" 
        }
    },
    // Partial Derivative
    {
        "key": "alt+p",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && editorLangId == 'latex'",
        "args": {
            "snippet": "\\partial " 
        }
    },
    // Math Roman (\mathrm)
    {
        "key": "alt+shift+r",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && editorLangId == 'latex'",
        "args": {
            "snippet": "\\mathrm{${1:$TM_SELECTED_TEXT}}$0" 
        }
    },
    // Summation
    {
        "key": "alt+s",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && editorLangId == 'latex'",
        "args": {
            "snippet": "\\sum_{$1}^{$2}$0"
        }
    },
    // Equation Environment
    {
        "key": "alt+e",
        "command": "editor.action.insertSnippet",
        "when": "editorTextFocus && editorLangId == 'latex'",
        "args":{
            "snippet":"\\begin{equation}\n\t${1:$TM_SELECTED_TEXT}\n\\end{equation}\n$0"
        } 
    }
]